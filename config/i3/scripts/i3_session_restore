#!/usr/bin/env python3
"""Restore i3 session saved by i3_session_save. Runs once per X session."""

import json
import os
import subprocess
import time
import sys

SESSION_FILE = os.path.expanduser('~/.config/i3/session/windows.json')
FLAG_FILE = os.path.expanduser('~/.config/i3/session/.restored')

# Known app classes → launch commands (fallback when exe path is unavailable)
KNOWN_APPS = {
    'firefox':        'firefox',
    'firefox-esr':    'firefox-esr',
    'chromium':       'chromium',
    'google-chrome':  'google-chrome',
    'thunar':         'thunar',
    'nautilus':       'nautilus',
    'geany':          'geany',
    'code':           'code',
    'obsidian':       'obsidian',
    'kitty':          'kitty',
    'alacritty':      'alacritty',
    'xterm':          'xterm',
    'burpsuite':      '/home/kali/BurpSuitePro/BurpSuite',
}


def get_launch_cmd(win):
    wm_class = (win.get('class') or '').lower()
    instance = (win.get('instance') or '').lower()

    # Prefer known mapping
    for key in (wm_class, instance):
        if key in KNOWN_APPS:
            return KNOWN_APPS[key]

    # Use saved exe if it still exists and is executable
    exe = win.get('exe', '')
    if exe and os.path.isfile(exe) and os.access(exe, os.X_OK):
        return exe

    # Try class/instance name as a PATH command
    for cmd in (wm_class, instance):
        if cmd:
            r = subprocess.run(['which', cmd], capture_output=True, text=True)
            if r.returncode == 0:
                return r.stdout.strip()

    return None


def wait_for_window(wm_class, timeout=6.0):
    """Return the most recently opened window ID matching wm_class, or None."""
    deadline = time.time() + timeout
    while time.time() < deadline:
        r = subprocess.run(
            ['xdotool', 'search', '--class', wm_class],
            capture_output=True, text=True,
        )
        if r.stdout.strip():
            return r.stdout.strip().split('\n')[-1]
        time.sleep(0.3)
    return None


def main():
    if not os.path.exists(SESSION_FILE):
        sys.exit(0)

    # Only restore once per X session (guard against i3 restarts)
    if os.path.exists(FLAG_FILE):
        sys.exit(0)

    with open(SESSION_FILE) as f:
        data = json.load(f)

    windows = data.get('windows', [])
    if not windows:
        sys.exit(0)

    # Group by workspace, preserving order
    workspaces: dict = {}
    for win in windows:
        ws = win['workspace']
        workspaces.setdefault(ws, []).append(win)

    for ws_name, ws_windows in workspaces.items():
        subprocess.run(['i3-msg', f'workspace {ws_name}'], capture_output=True)
        time.sleep(0.2)

        for win in ws_windows:
            cmd = get_launch_cmd(win)
            if not cmd:
                continue

            subprocess.Popen(
                [cmd],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )

            if win.get('floating') and win.get('class'):
                win_id = wait_for_window(win['class'])
                if win_id:
                    subprocess.run(
                        ['xdotool', 'windowmove', win_id,
                         str(win['x']), str(win['y'])],
                        capture_output=True,
                    )
                    subprocess.run(
                        ['xdotool', 'windowsize', win_id,
                         str(win['width']), str(win['height'])],
                        capture_output=True,
                    )
            else:
                time.sleep(0.2)

    # Mark restored so i3 restarts during this session skip the restore
    open(FLAG_FILE, 'w').close()


if __name__ == '__main__':
    main()
